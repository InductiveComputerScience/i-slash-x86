Bgs base64AS
  ; Input
  u8a data
  u64 datap
  u8x16a datax
  s64 dataLength
  
  ; Output
  u8x16a output
  
  ; Working vars
  s64 len
  s64 i
  u64 j
  b1 tb10
  u8x16 elementu
  b8x16 element
  b8x16 in
  u32x4 t0
  u32x4 t1
  u32x4 t2
  u32x4 t3
  u8x16 less
  u8x16 input
  b8x16 result
  u8x16 resultu
  u8x16 d
  u32x4 resultx
  u8x16 upx
  u32 z
  u8x16 tu8x160
  u8 c
  
  ; Constants
  u8x16 cInputShuffle
  u32x4 c1
  u32x4 c2
  u32x4 c3
  u32x4 c4
  u8x16 c5
  u8x16 c6
  u8x16 c7
  u8x16 cLut
  b8x16 cLutb
Ens

Fnc base64A

  ; Set up constants
  ; Look up table
  Mov c, 'a'
  Sub c, c, 26
  Idw cLut, 0, c
  Mov c, '0'
  Sub c, c, 52
  Idw cLut, 1, c
  Idw cLut, 2, c
  Idw cLut, 3, c

  Idw cLut, 4, c
  Idw cLut, 5, c
  Idw cLut, 6, c
  Idw cLut, 7, c

  Idw cLut, 8, c
  Idw cLut, 9, c
  Idw cLut, 10, c
  Mov c, '+'
  Sub c, c, 62
  Idw cLut, 11, c

  Mov c, '/'
  Sub c, c, 63
  Idw cLut, 12, c
  Idw cLut, 13, 'A'
  Idw cLut, 14, 0
  Idw cLut, 15, 0

  Xb8x16 cLutb, cLut
  
  Idw cInputShuffle, 0, 1
  Idw cInputShuffle, 1, 0
  Idw cInputShuffle, 2, 2
  Idw cInputShuffle, 3, 1

  Idw cInputShuffle, 4, 4
  Idw cInputShuffle, 5, 3
  Idw cInputShuffle, 6, 5
  Idw cInputShuffle, 7, 4

  Idw cInputShuffle, 8, 7
  Idw cInputShuffle, 9, 6
  Idw cInputShuffle, 10, 8
  Idw cInputShuffle, 11, 7

  Idw cInputShuffle, 12, 10
  Idw cInputShuffle, 13, 9
  Idw cInputShuffle, 14, 11
  Idw cInputShuffle, 15, 10
  
  Mov c1, 0x0fc0fc00
  Mov c2, 0x04000040
  Mov c3, 0x003f03f0
  Mov c4, 0x01000010
  
  Mov c5, 51
  Mov c6, 26
  Mov c7, 13

  ; We have to have 4 extra bytes on the end because we need 12 bytes in each iteration in a 16 bit register, so we need that 4 byte padding.
  Sub dataLength, dataLength, 4
  
  ; We do 12 bytes in each iteration
  Div len, dataLength, 12
  
  ; We use a raw pointer to data
  Xu64 datap, data

  ; i is our tracks input progress, j track output progress
  Mov i, 0
  Mov j, 0
  
  Loop
  If exp b: i < len

    ; Read our data pointer
    Xu8x16a datax, datap
    Idr elementu, datax, 0
    Xb8x16 element, elementu

    ; Part 1  
    Shuffle in, element, cInputShuffle
    
    ; Part 2
    ;And t0, in, c1
    MulStoreHigh t1, t0, c2
    ;And t0, in, c3
    Mul t0, t0, c4
    ;Or input, t1, t0

    ; Part 3
    SubSaturated resultu, input, c5
    Xb8x16 result, resultu
    ;exp b u8x16: result = ((c6 > input) & c7) | result
    Shuffle result, cLutb, result
    Xu8x16 resultu, result
    Add resultu, resultu, input
    
    ; Write result
    Idw output, i, resultu
    
    Inc i
    
    ; Move input pointer forward 12 bytes
    Add datap, datap, 12
  EndLoop
  
  ; Compute the final number of triplets processed
  Mul i, i, 4
  
Ret



















